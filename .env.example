# Copy to `.env` and fill values. Compose reads this file automatically.

# --- Veeam-Sync (optional) --------------------------------------------------
# Token for POST /api/sync. While empty, the endpoint is disabled (503).
# Set the same value as BACKUP_CHECK_TOKEN on the Veeam host.
SYNC_TOKEN=

# --- User sessions (required) ----------------------------------------------
# Secret for signing JWT session cookies. MUST be set and kept stable.
# Generate e.g. via PowerShell:  [guid]::NewGuid().Guid
# Or on Linux:                   openssl rand -hex 32
AUTH_SECRET=

# Set to 1 when serving the app over HTTPS (e.g. via nginx/Caddy in front).
# LAN-only HTTP: leave at 0.
COOKIE_SECURE=0

# Initial admin credentials — only used on first start when users table is empty.
# After the first start, change the password via the user menu or /users page.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin
