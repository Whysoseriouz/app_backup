# Copy this file to `.env` and fill in a strong random value.
# While SYNC_TOKEN is empty, the /api/sync endpoint is disabled (503).
#
# Suggested ways to generate a token:
#   PowerShell:  [guid]::NewGuid().Guid
#   Linux/Mac:   openssl rand -hex 32
#
# The same value must be set as BACKUP_CHECK_TOKEN on the host that runs
# sync-veeam.ps1.

SYNC_TOKEN=
